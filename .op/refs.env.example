# Copy to refs.env in this directory (gitignored).
# 1Password: Developer → Environments → open your local dev environment → copy Environment ID.
#
#   cp .op/refs.env.example .op/refs.env
#
# Then `bun run dev` runs under `op run --environment …` and builds .dev.vars from .dev.vars.example.

OP_ENVIRONMENT_ID=
