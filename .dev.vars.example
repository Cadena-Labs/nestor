# --- Or: inline Worker secrets (no Connect) / overrides when Connect omits a field ---
ENCRYPTION_KEY=
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWT_KEY=
CLERK_API_URL=
CLERK_DOMAIN=
CLERK_PROXY_URL=
CLERK_IS_SATELLITE=
DISABLE_LOG_TOOLS=
MAX_TOOL_OUTPUT_CHARS=
CHAT_MAX_STEPS=
CHAT_MAX_LOGS=

