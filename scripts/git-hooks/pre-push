#!/usr/bin/env bash
set -euo pipefail

# shellcheck disable=SC2034  # names supplied by Git
remote="$1"
url="$2"

while read -r local_ref local_sha remote_ref remote_sha; do
	if [ "${local_sha}" = "0000000000000000000000000000000000000000" ]; then
		continue
	fi

	if [ "${remote_sha}" = "0000000000000000000000000000000000000000" ]; then
		range="${local_sha}"
	else
		range="${remote_sha}..${local_sha}"
	fi

	while IFS= read -r commit; do
		[ -z "${commit}" ] && continue
		if ! git verify-commit "${commit}" >/dev/null 2>&1; then
			echo "pre-push: commit ${commit} is not signed or signature verification failed." >&2
			echo "Sign with: git rebase -i --exec 'git commit --amend --no-edit -S' <upstream>" >&2
			echo "Or fix your signing setup (gpg.format, signing key, agent)." >&2
			exit 1
		fi
	done < <(git rev-list "${range}")
done

exit 0
