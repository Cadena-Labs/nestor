{
	"name": "nestor",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "react-router build",
		"cf-typegen": "wrangler types",
		"deploy": "bun run build && wrangler deploy",
		"dev": "react-router dev",
		"postinstall": "bun run cf-typegen",
		"preview": "bun run build && vite preview",
		"test": "bun test",
		"secrets:sync": "bun run scripts/op-sync-wrangler-secrets.ts",
		"secrets:sync:dry-run": "bun run scripts/op-sync-wrangler-secrets.ts --dry-run",
		"typecheck": "bun run cf-typegen && react-router typegen && tsc -b"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^1",
		"@ai-sdk/openai": "^1",
		"@assistant-ui/react": "^0",
		"@assistant-ui/react-ai-sdk": "^0",
		"@clerk/react-router": "^3.0.6",
		"ai": "^4",
		"fast-xml-parser": "^5",
		"isbot": "^5.1.31",
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"react-router": "^7.10.0"
	},
	"devDependencies": {
		"@1password/sdk": "0.4.1-beta.1",
		"@cloudflare/vite-plugin": "^1.13.5",
		"@react-router/dev": "^7.10.0",
		"@tailwindcss/vite": "^4.1.13",
		"@types/node": "^25.5.0",
		"@types/react": "^19.1.13",
		"@types/react-dom": "^19.1.9",
		"tailwindcss": "^4.1.13",
		"typescript": "^5.9.2",
		"vite": "^7.1.7",
